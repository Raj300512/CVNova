{
  "manifest_version": 3,
  "name": "CVNova Companion",
  "version": "1.0",
  "description": "Smart Job-Hunt assistant. Get instant match scores from CVNova.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/viewjob*",
        "https://*.indeed.com/viewjob*",
        "https://www.glassdoor.com/job-listing/*",
        "https://www.glassdoor.co.in/job-listing/*",
        "https://wellfound.com/jobs/*",
        "https://www.naukri.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8080/*",
    "https://*/*"
  ]
}
