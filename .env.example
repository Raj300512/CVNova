# ─── CVNova Environment Variables ────────────────────────────────────────────
# Yeh file GitHub pe push karo — actual values NAHI daalni hain
# Vercel Dashboard > Settings > Environment Variables mein yeh sab add karo

# Flask
SECRET_KEY=your-super-secret-random-key-here   # python -c "import secrets; print(secrets.token_hex(32))"
FLASK_ENV=production

# Database (Vercel pe SQLite kaam nahi karta — Neon/Supabase free PostgreSQL use karo)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI APIs
GEMINI_API_KEY=your-gemini-api-key
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/gpt-4o-mini/chat/completions?api-version=2025-01-01-preview
GITHUB_TOKEN=your-github-token

# Job Search
JSEARCH_API_KEY=your-jsearch-rapidapi-key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (optional — Mailgun/SendGrid free tier)
MAIL_SERVER=smtp.mailgun.org
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=noreply@cvnova.ai
